{
  "name": "@ricky/openclaw-photos",
  "version": "0.1.0",
  "description": "Tag-based photo library plugin for OpenClaw — save, random retrieve, list, delete.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/schema.sql dist/schema.sql",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "better-sqlite3": "^12.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "vitest": "^3.1.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "license": "MIT"
}
